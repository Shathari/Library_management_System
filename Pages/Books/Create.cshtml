@page
@model LMS.Razor.Pages.Books.CreateModel
<h2>Add Book</h2>

<form method="post">
    <div>
        <label>Title</label><br />
        <input asp-for="Title" />
    </div>
    <div>
        <label>Author</label><br />
        <input asp-for="Author" />
    </div>
    <div>
        <label>Copies</label><br />
        <input asp-for="AvailableCopies" type="number" min="0" />
    </div>
    <p style="color:red">@Html.ValidationSummary()</p>
    <button type="submit">Save</button>
    <a asp-page="Index">Cancel</a>
</form>