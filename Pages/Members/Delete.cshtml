@page "{id:int}"
@model LMS.Razor.Pages.Members.DeleteModel
@{
    ViewData["Title"] = "Delete Member";

    // Assuming Model.Member is a DataRow or IDictionary<string, object>
    var dr = Model.Member;

    DateTime? createdAt = null;
    if (dr != null && dr["CreatedAt"] != DBNull.Value)
    {
        createdAt = (DateTime)dr["CreatedAt"];
    }

    int? memberId = null;
    if (dr != null && dr["MemberId"] != DBNull.Value)
    {
        memberId = Convert.ToInt32(dr["MemberId"]);
    }
}

<h2 class="mb-3">Delete Member</h2>

@if (Model.Member is null)
{
    <div class="alert alert-warning">Member not found.</div>
}
else
{
    <div class="alert alert-danger">
        Are you sure you want to delete <strong>@Model.Member["FullName"]</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Member["Email"]</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Member["Phone"]</dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@((createdAt?.ToString("dd-MMM-yyyy HH:mm")) ?? "-")</dd>
    </dl>

    <form method="post" asp-route-id="@(memberId)">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-page="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
}