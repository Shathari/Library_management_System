@page
@model LMS.Razor.Pages.Members.IndexModel
@{
    ViewData["Title"] = "Members";
}

<h2 class="mb-3">Members</h2>

<p>
    <a class="btn btn-primary" asp-page="Create">+ Add Member</a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>MemberId</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Created At</th>
            <th style="width: 160px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (System.Data.DataRow row in Model.MembersTable.Rows)
    {
        var createdAt = row["CreatedAt"] == DBNull.Value ? (DateTime?)null : (DateTime)row["CreatedAt"];
        <tr>
            <td>@row["MemberId"]</td>
            <td>@row["FullName"]</td>
            <td>@row["Email"]</td>
            <td>@row["Phone"]</td>
            <td>@(createdAt?.ToString("dd-MMM-yyyy HH:mm") ?? "-")</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@row["MemberId"]">Edit</a>
                <a class="btn btn-sm btn-outline-danger ms-1" asp-page="Delete" asp-route-id="@row["MemberId"]">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>